#!/bin/bash

unset PREFIX npm_config_prefix
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm

WORKSPACE_BRANCH="${1:-${SOLIDOS_WORKSPACE_BRANCH:-}}"

if [[ -n "$WORKSPACE_BRANCH" && -z "${SOLIDOS_BRANCH_SYNCED:-}" ]]; then
  scripts/sync-workspace-branch "$WORKSPACE_BRANCH"
fi

scripts/stop-pivot >/dev/null 2>&1 || true

link_workspace_dependency () {
	local dep_name="$1"
	local dep_path

	while IFS= read -r dep_path
	do
		rm -rf "$dep_path"
		ln -s "../../$dep_name" "$dep_path"
	done < <(find workspaces -maxdepth 3 -path "*/node_modules/$dep_name" -type d)
}

npx lerna bootstrap --force-local

# npm auto-installs peer deps inside package-local node_modules; replace them with workspace links.
link_workspace_dependency "rdflib"
link_workspace_dependency "solid-logic"
link_workspace_dependency "solid-ui"
link_workspace_dependency "profile-pane"

cd workspaces/pivot
nvm use --delete-prefix
# npm run start
command='npx community-solid-server -c ./config/dev-http-suffix.json config/customise-me.json -f ./data-suffix -p 3100 -b http://localhost:3100 -m .'
# nohup $command > /dev/null 2>&1 &
$command
